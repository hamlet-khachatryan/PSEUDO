    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import optuna\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from mpl_toolkits.axes_grid1.inset_locator import inset_axes, mark_inset\\n\",\n",
    "    \"from optuna.storages import JournalStorage, JournalFileStorage\\n\",\n",
    "    \"\\n\",\n",
    "    \"JOURNAL_PATH = \\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/optuna_optimisation_final/study_robust_top.log\\\"\\n\",\n",
    "    \"STUDY_NAME = \\\"study_robust_top\\\"  # Must match the name used in your optimization\\n\",\n",
    "    \"OUTPUT_FILE = \\\"optuna_plot.pdf\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Plot Styling\\n\",\n",
    "    \"plt.rcParams['font.family'] = 'sans-serif'\\n\",\n",
    "    \"plt.rcParams['font.sans-serif'] = ['Arial', 'DejaVu Sans']\\n\",\n",
    "    \"plt.rcParams['pdf.fonttype'] = 42\\n\",\n",
    "    \"plt.rcParams['ps.fonttype'] = 42\\n\",\n",
    "    \"\\n\",\n",
    "    \"def main():\\n\",\n",
    "    \"    # 1. Load Study\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        storage = JournalStorage(JournalFileStorage(LOG_FILE))\\n\",\n",
    "    \"        study = optuna.load_study(study_name=STUDY_NAME, storage=storage)\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"Error loading study: {e}\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. Extract Data\\n\",\n",
    "    \"    trials = [t for t in study.trials if t.state == optuna.trial.TrialState.COMPLETE]\\n\",\n",
    "    \"    if not trials:\\n\",\n",
    "    \"        print(\\\"No complete trials found.\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    values = np.array([t.values for t in trials])\\n\",\n",
    "    \"    trial_numbers = np.array([t.number for t in trials])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Extract 'mode' for marker shape\\n\",\n",
    "    \"    modes = []\\n\",\n",
    "    \"    for t in trials:\\n\",\n",
    "    \"        # Check params for 'mode' (handles internal index or string mapping)\\n\",\n",
    "    \"        # In your log, 0='amino_acids', 1='atoms'. Optuna might return the string directly if distribution is categorical.\\n\",\n",
    "    \"        m = t.params.get('mode', 'Unknown')\\n\",\n",
    "    \"        modes.append(m)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 3. Infer Indices\\n\",\n",
    "    \"    mean_vals = np.mean(values, axis=0)\\n\",\n",
    "    \"    sorted_indices = np.argsort(mean_vals)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    idx_p10 = sorted_indices[0] # P10 (Conservative)\\n\",\n",
    "    \"    idx_med = sorted_indices[1] # Median (Size)\\n\",\n",
    "    \"    idx_p90 = sorted_indices[2] # P90 (Optimistic)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Mapping: X=Obj{idx_p10} (P10), Y=Obj{idx_p90} (P90), Size=Obj{idx_med} (Median)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 4. Identify Special Sets\\n\",\n",
    "    \"    pareto_trials = study.best_trials\\n\",\n",
    "    \"    pareto_nums = [t.number for t in pareto_trials]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Best Balanced Heuristic\\n\",\n",
    "    \"    p_vals = np.array([t.values for t in pareto_trials])\\n\",\n",
    "    \"    p_norm = (p_vals - p_vals.min(axis=0)) / (p_vals.max(axis=0) - p_vals.min(axis=0) + 1e-9)\\n\",\n",
    "    \"    dists = np.linalg.norm(p_norm - 1.0, axis=1)\\n\",\n",
    "    \"    best_trial_num = pareto_trials[np.argmin(dists)].number\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 5. Build DataFrame\\n\",\n",
    "    \"    df = pd.DataFrame({\\n\",\n",
    "    \"        'Trial': trial_numbers,\\n\",\n",
    "    \"        'P10': values[:, idx_p10],\\n\",\n",
    "    \"        'Median': values[:, idx_med],\\n\",\n",
    "    \"        'P90': values[:, idx_p90],\\n\",\n",
    "    \"        'Mode': modes,\\n\",\n",
    "    \"        'Status': 'Trial'\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"\\n\",\n",
    "    \"    df.loc[df['Trial'].isin(pareto_nums), 'Status'] = 'Pareto Front'\\n\",\n",
    "    \"    df.loc[df['Trial'] == best_trial_num, 'Status'] = 'Best Balanced'\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 6. Plotting Setup\\n\",\n",
    "    \"    fig, ax = plt.subplots(figsize=(10, 7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # COLORS & STYLES\\n\",\n",
    "    \"    palette_colors = {\\n\",\n",
    "    \"        'Trial': '#b8c6db',          # Pastel Lavender (Soft cloud)\\n\",\n",
    "    \"        'Pareto Front': '#457b9d',   # Strong Blue\\n\",\n",
    "    \"        'Best Balanced': '#e63946'   # Bright Red/Gold\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    markers_map = {\\n\",\n",
    "    \"        'amino_acids': 'o',\\n\",\n",
    "    \"        'atoms': 's'  # Square marker for Atoms\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def get_norm_size(column):\\n\",\n",
    "    \"        v_min, v_max = df['Median'].min(), df['Median'].max()\\n\",\n",
    "    \"        return 50 + 200 * (column - v_min) / (v_max - v_min + 1e-9)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- MAIN SCATTER LOOP ---\\n\",\n",
    "    \"    for status in ['Trial', 'Pareto Front', 'Best Balanced']:\\n\",\n",
    "    \"        subset = df[df['Status'] == status]\\n\",\n",
    "    \"        if subset.empty: continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for mode in subset['Mode'].unique():\\n\",\n",
    "    \"            sub_mode = subset[subset['Mode'] == mode]\\n\",\n",
    "    \"            if sub_mode.empty: continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Style configuration\\n\",\n",
    "    \"            color = palette_colors[status]\\n\",\n",
    "    \"            marker = markers_map.get(mode, 'o')\\n\",\n",
    "    \"            edge = 'white' if status == 'Trial' else 'black'\\n\",\n",
    "    \"            lw = 0.5 if status == 'Trial' else 1.5\\n\",\n",
    "    \"            z = 1 if status == 'Trial' else 10\\n\",\n",
    "    \"            alpha = 0.7 if status == 'Trial' else 1.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"            sizes = get_norm_size(sub_mode['Median'])\\n\",\n",
    "    \"            if status == 'Best Balanced': sizes *= 1.5\\n\",\n",
    "    \"\\n\",\n",
    "    \"            ax.scatter(\\n\",\n",
    "    \"                sub_mode['P10'], sub_mode['P90'],\\n\",\n",
    "    \"                s=sizes, c=color, marker=marker,\\n\",\n",
    "    \"                edgecolors=edge, linewidths=lw, alpha=alpha, zorder=z\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- INSET ZOOM: Focus on 'ATOMS' Mode ---\\n\",\n",
    "    \"    # 1. Calculate bounds of ALL 'atoms' mode trials\\n\",\n",
    "    \"    atoms_data = df[df['Mode'] == 'atoms']\\n\",\n",
    "    \"\\n\",\n",
    "    \"    if not atoms_data.empty:\\n\",\n",
    "    \"        x_min, x_max = atoms_data['P10'].min(), atoms_data['P10'].max()\\n\",\n",
    "    \"        y_min, y_max = atoms_data['P90'].min(), atoms_data['P90'].max()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Add padding to frame them nicely\\n\",\n",
    "    \"        pad_x = (x_max - x_min) * 0.15\\n\",\n",
    "    \"        pad_y = (y_max - y_min) * 0.15\\n\",\n",
    "    \"        if pad_x == 0: pad_x = 0.01\\n\",\n",
    "    \"        if pad_y == 0: pad_y = 0.01\\n\",\n",
    "    \"\\n\",\n",
    "    \"        x_lims = (x_min - pad_x, x_max + pad_x)\\n\",\n",
    "    \"        y_lims = (y_min - pad_y, y_max + pad_y)\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        # Fallback if no atoms trials exist\\n\",\n",
    "    \"        x_lims = ax.get_xlim()\\n\",\n",
    "    \"        y_lims = ax.get_ylim()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. Create Inset Axes\\n\",\n",
    "    \"    axins = inset_axes(ax, width=\\\"40%\\\", height=\\\"40%\\\", loc='lower right', borderpad=3)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 3. Re-plot data inside inset\\n\",\n",
    "    \"    for _, row in df.iterrows():\\n\",\n",
    "    \"        status = row['Status']\\n\",\n",
    "    \"        mode = row['Mode']\\n\",\n",
    "    \"\\n\",\n",
    "    \"        color = palette_colors[status]\\n\",\n",
    "    \"        marker = markers_map.get(mode, 'o')\\n\",\n",
    "    \"        edge = 'black' if status != 'Trial' else 'none'\\n\",\n",
    "    \"        alpha = 1.0 if status != 'Trial' else 0.5\\n\",\n",
    "    \"        z = 10 if status != 'Trial' else 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        s = get_norm_size(row['Median'])\\n\",\n",
    "    \"        # Optional: scale down points inside inset slightly if too crowded\\n\",\n",
    "    \"\\n\",\n",
    "    \"        axins.scatter(\\n\",\n",
    "    \"            row['P10'], row['P90'],\\n\",\n",
    "    \"            s=s, c=color, marker=marker,\\n\",\n",
    "    \"            edgecolors=edge, alpha=alpha, zorder=z\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Apply calculated limits to zoom in on Atoms\\n\",\n",
    "    \"    axins.set_xlim(*x_lims)\\n\",\n",
    "    \"    axins.set_ylim(*y_lims)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Cleanup Inset\\n\",\n",
    "    \"    axins.set_xticks([])\\n\",\n",
    "    \"    axins.set_yticks([])\\n\",\n",
    "    \"    axins.grid(True, linestyle=':', alpha=0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Connect box\\n\",\n",
    "    \"    mark_inset(ax, axins, loc1=2, loc2=4, fc=\\\"none\\\", ec=\\\"0.5\\\", linestyle='--')\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- LEGEND & LABELS ---\\n\",\n",
    "    \"    ax.set_xlabel(\\\"P10 (Conservative Estimate)\\\", fontsize=12, fontweight='bold')\\n\",\n",
    "    \"    ax.set_ylabel(\\\"P90 (Optimistic Estimate)\\\", fontsize=12, fontweight='bold')\\n\",\n",
    "    \"    ax.set_title(\\\"Optimization Landscape: Atoms Mode Focus\\\", fontsize=14, pad=15)\\n\",\n",
    "    \"    ax.grid(True, linestyle='--', alpha=0.3)\\n\",\n",
    "    \"    sns.despine()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Custom Legend\\n\",\n",
    "    \"    from matplotlib.lines import Line2D\\n\",\n",
    "    \"    legend_elements = [\\n\",\n",
    "    \"        Line2D([0], [0], marker='o', color='w', markerfacecolor=palette_colors['Trial'], markersize=8, label='Explored Trials'),\\n\",\n",
    "    \"        Line2D([0], [0], marker='o', color='w', markerfacecolor=palette_colors['Pareto Front'], markersize=8, label='Pareto Front'),\\n\",\n",
    "    \"        Line2D([0], [0], marker='*', color='w', markerfacecolor=palette_colors['Best Balanced'], markersize=12, markeredgecolor='k', label='Best Balanced'),\\n\",\n",
    "    \"        Line2D([0], [0], color='w', label=' '), # Spacer\\n\",\n",
    "    \"        Line2D([0], [0], marker='o', color='w', markerfacecolor='gray', markeredgecolor='k', markersize=8, label='Mode: Amino Acids'),\\n\",\n",
    "    \"        Line2D([0], [0], marker='s', color='w', markerfacecolor='gray', markeredgecolor='k', markersize=8, label='Mode: Atoms'),\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"    ax.legend(handles=legend_elements, loc='upper left', frameon=True, fontsize=10, framealpha=0.95)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.savefig(OUTPUT_FILE, dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"    print(f\\\"Plot saved to {OUTPUT_FILE}\\\")\\n\",\n",
