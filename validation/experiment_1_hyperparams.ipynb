    "   \"cell_type\": \"code\",\n",
    "   \"source\": \"calculate_map_cc(f\\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/merged_intensities/{id}-sf/baseline_maps/calculated_density.ccp4\\\",f\\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/merged_intensities/{id}-sf/baseline_maps/experimntal_density.ccp4\\\")\",\n",
    "   \"id\": \"810b633d4ffadb36\",\n",
    "   \"outputs\": [\n",
    "    {\n",
    "     \"data\": {\n",
    "      \"text/plain\": [\n",
    "       \"(0.53247064, 'SPeearman:', 0.4308264408718322, 'SPeearman P:', 0.0)\"\n",
    "      ]\n",
    "     },\n",
    "     \"execution_count\": 41,\n",
