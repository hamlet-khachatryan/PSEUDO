    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import mrcfile\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"\\n\",\n",
    "    \"def calculate_map_cc_mrcfile(map_path_1, map_path_2):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Reads two CCP4/MRC maps using mrcfile and computes the CC.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    # 1. Open both files\\n\",\n",
    "    \"    with mrcfile.open(map_path_1) as mrc1, mrcfile.open(map_path_2) as mrc2:\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 2. Extract data arrays\\n\",\n",
    "    \"        data1 = mrc1.data\\n\",\n",
    "    \"        data2 = mrc2.data\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 3. Check shapes\\n\",\n",
    "    \"        if data1.shape != data2.shape:\\n\",\n",
    "    \"            raise ValueError(\\n\",\n",
    "    \"                f\\\"Shape mismatch: {data1.shape} vs {data2.shape}. \\\"\\n\",\n",
    "    \"                \\\"Resampling is required if shapes differ.\\\"\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 4. Flatten arrays to 1D vectors\\n\",\n",
    "    \"        flat1 = data1.flatten()\\n\",\n",
    "    \"        flat2 = data2.flatten()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 5. Calculate CC manually (faster than corrcoef for very large arrays)\\n\",\n",
    "    \"        # This avoids creating the covariance matrix if memory is tight\\n\",\n",
    "    \"        mean1 = np.mean(flat1)\\n\",\n",
    "    \"        mean2 = np.mean(flat2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        centered_1 = flat1 - mean1\\n\",\n",
    "    \"        centered_2 = flat2 - mean2\\n\",\n",
    "    \"\\n\",\n",
    "    \"        numerator = np.sum(centered_1 * centered_2)\\n\",\n",
    "    \"        denominator = np.sqrt(np.sum(centered_1**2)) * np.sqrt(np.sum(centered_2**2))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return numerator / denominator\"\n",
    "   ],\n",
    "   \"id\": \"205e7575d1d227df\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 13\n",
    "  },\n",
