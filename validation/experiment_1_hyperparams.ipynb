    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"\\n\",\n",
    "    \"JOURNAL_PATH = \\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/optuna_optimisation_final/study_robust_top.log\\\"\\n\",\n",
    "    \"STUDY_NAME = \\\"study_robust_top\\\"  # Must match the name used in your optimization\\n\",\n",
    "    \"OUTPUT_FILE = \\\"optuna_plot.pdf\\\"\\n\",\n",
    "    \"import optuna\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"from mpl_toolkits.axes_grid1.inset_locator import inset_axes, mark_inset\\n\",\n",
    "    \"from optuna.storages import JournalStorage, JournalFileStorage\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# Plot Styling\\n\",\n",
    "    \"plt.rcParams['font.family'] = 'sans-serif'\\n\",\n",
    "    \"plt.rcParams['font.sans-serif'] = ['Arial', 'DejaVu Sans']\\n\",\n",
    "    \"plt.rcParams['pdf.fonttype'] = 42\\n\",\n",
    "    \"plt.rcParams['ps.fonttype'] = 42\\n\",\n",
    "    \"\\n\",\n",
    "    \"def main():\\n\",\n",
    "    \"    # 1. Load Study\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        storage = JournalStorage(JournalFileStorage(JOURNAL_PATH))\\n\",\n",
    "    \"        study = optuna.load_study(study_name=STUDY_NAME, storage=storage)\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"Error loading study: {e}\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. Extract Data\\n\",\n",
    "    \"    trials = [t for t in study.trials if t.state == optuna.trial.TrialState.COMPLETE]\\n\",\n",
    "    \"    if not trials:\\n\",\n",
    "    \"        print(\\\"No complete trials found.\\\")\\n\",\n",
    "    \"        return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Convert values to numpy array\\n\",\n",
    "    \"    values = np.array([t.values for t in trials])\\n\",\n",
    "    \"    trial_numbers = np.array([t.number for t in trials])\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Extract 'mode' parameter for marker shape\\n\",\n",
    "    \"    # We map internal index 0/1 back to names if needed, or just use the string\\n\",\n",
    "    \"    modes = []\\n\",\n",
    "    \"    for t in trials:\\n\",\n",
    "    \"        # Optuna stores categorical params as the index (0, 1) in params_internal,\\n\",\n",
    "    \"        # but usually returns the actual value in t.params['mode']\\n\",\n",
    "    \"        modes.append(t.params.get('mode', 'Unknown'))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 3. Infer Indices for P10 (X), Median (Size), P90 (Y)\\n\",\n",
    "    \"    mean_vals = np.mean(values, axis=0)\\n\",\n",
    "    \"    sorted_indices = np.argsort(mean_vals)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    idx_p10 = sorted_indices[0] # Smallest avg -> P10\\n\",\n",
    "    \"    idx_med = sorted_indices[1] # Middle avg -> Median\\n\",\n",
    "    \"    idx_p90 = sorted_indices[2] # Largest avg -> P90\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Mapping: X=Obj{idx_p10} (P10), Y=Obj{idx_p90} (P90), Size=Obj{idx_med} (Median)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 4. Identify Pareto & Best\\n\",\n",
    "    \"    pareto_trials = study.best_trials\\n\",\n",
    "    \"    pareto_nums = [t.number for t in pareto_trials]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Calculate 'Best Balanced' (Closest to normalized 1,1,1)\\n\",\n",
    "    \"    p_vals = np.array([t.values for t in pareto_trials])\\n\",\n",
    "    \"    # Normalize Pareto subset to 0-1\\n\",\n",
    "    \"    p_min, p_max = p_vals.min(axis=0), p_vals.max(axis=0)\\n\",\n",
    "    \"    p_norm = (p_vals - p_min) / (p_max - p_min + 1e-9)\\n\",\n",
    "    \"    # Distance to ideal (1,1,1)\\n\",\n",
    "    \"    dists = np.linalg.norm(p_norm - 1.0, axis=1)\\n\",\n",
    "    \"    best_idx_local = np.argmin(dists)\\n\",\n",
    "    \"    best_trial_num = pareto_trials[best_idx_local].number\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 5. Build DataFrame\\n\",\n",
    "    \"    df = pd.DataFrame({\\n\",\n",
    "    \"        'Trial': trial_numbers,\\n\",\n",
    "    \"        'P10': values[:, idx_p10],\\n\",\n",
    "    \"        'Median': values[:, idx_med],\\n\",\n",
    "    \"        'P90': values[:, idx_p90],\\n\",\n",
    "    \"        'Mode': modes,\\n\",\n",
    "    \"        'Status': 'Trial' # Default\\n\",\n",
    "    \"    })\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Update Status labels\\n\",\n",
    "    \"    df.loc[df['Trial'].isin(pareto_nums), 'Status'] = 'Pareto Front'\\n\",\n",
    "    \"    df.loc[df['Trial'] == best_trial_num, 'Status'] = 'Best Balanced'\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 6. Setup Plot\\n\",\n",
    "    \"    fig, ax = plt.subplots(figsize=(10, 7))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Define Colors (Pastel for history, Bold for best)\\n\",\n",
    "    \"    # Using a soft pastel teal for the history points\\n\",\n",
    "    \"    palette_colors = {\\n\",\n",
    "    \"        'Trial': '#a8dadc',          # Pastel Blue/Green (Soft)\\n\",\n",
    "    \"        'Pareto Front': '#457b9d',   # Strong Blue\\n\",\n",
    "    \"        'Best Balanced': '#e63946'   # Bright Red/Gold\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Define Markers for Modes\\n\",\n",
    "    \"    # Amino Acids = Circle, Atoms = Square (or Diamond 'D')\\n\",\n",
    "    \"    markers_map = {\\n\",\n",
    "    \"        'amino_acids': 'o',\\n\",\n",
    "    \"        'atoms': 's'  # Square\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Helper to calculate size array (scaled for visibility)\\n\",\n",
    "    \"    def get_sizes(data_col):\\n\",\n",
    "    \"        # Normalize 0-1 then scale to 50-250 range\\n\",\n",
    "    \"        v_min, v_max = df['Median'].min(), df['Median'].max()\\n\",\n",
    "    \"        norm = (data_col - v_min) / (v_max - v_min + 1e-9)\\n\",\n",
    "    \"        return 50 + 200 * norm\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- MAIN PLOT LOOP ---\\n\",\n",
    "    \"    # We plot in layers to ensure Best is on top\\n\",\n",
    "    \"    for status in ['Trial', 'Pareto Front', 'Best Balanced']:\\n\",\n",
    "    \"        subset = df[df['Status'] == status]\\n\",\n",
    "    \"        if subset.empty: continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Split by Mode to handle markers\\n\",\n",
    "    \"        for mode in subset['Mode'].unique():\\n\",\n",
    "    \"            sub_mode = subset[subset['Mode'] == mode]\\n\",\n",
    "    \"            if sub_mode.empty: continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Style logic\\n\",\n",
    "    \"            color = palette_colors[status]\\n\",\n",
    "    \"            marker = markers_map.get(mode, 'o')\\n\",\n",
    "    \"            edge_color = 'white' if status == 'Trial' else 'black'\\n\",\n",
    "    \"            lw = 0.5 if status == 'Trial' else 1.5\\n\",\n",
    "    \"            z_order = 1 if status == 'Trial' else (5 if status == 'Pareto Front' else 10)\\n\",\n",
    "    \"            alpha = 0.6 if status == 'Trial' else 0.9\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # For 'Best Balanced', make it strictly a Star regardless of mode?\\n\",\n",
    "    \"            # Or keep mode shape but make it huge?\\n\",\n",
    "    \"            # Request asked for marker sign for omission mode, so we keep shape\\n\",\n",
    "    \"            # but maybe add a halo or specific color.\\n\",\n",
    "    \"\\n\",\n",
    "    \"            size_vals = get_sizes(sub_mode['Median'])\\n\",\n",
    "    \"            if status == 'Best Balanced':\\n\",\n",
    "    \"                size_vals = size_vals * 1.5 # Make winner larger\\n\",\n",
    "    \"\\n\",\n",
    "    \"            ax.scatter(\\n\",\n",
    "    \"                sub_mode['P10'], sub_mode['P90'],\\n\",\n",
    "    \"                s=size_vals,\\n\",\n",
    "    \"                c=color,\\n\",\n",
    "    \"                marker=marker,\\n\",\n",
    "    \"                edgecolors=edge_color,\\n\",\n",
    "    \"                linewidths=lw,\\n\",\n",
    "    \"                alpha=alpha,\\n\",\n",
    "    \"                zorder=z_order,\\n\",\n",
    "    \"                label=f\\\"{status} ({mode})\\\" if status != 'Trial' else None # Cleaner legend\\n\",\n",
    "    \"            )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Add simplified legend manually to avoid duplicate/messy labels\\n\",\n",
    "    \"    # 1. Color Legend\\n\",\n",
    "    \"    from matplotlib.lines import Line2D\\n\",\n",
    "    \"    legend_elements = [\\n\",\n",
    "    \"        Line2D([0], [0], marker='o', color='w', markerfacecolor=palette_colors['Trial'], markersize=8, label='Explored Trials'),\\n\",\n",
    "    \"        Line2D([0], [0], marker='o', color='w', markerfacecolor=palette_colors['Pareto Front'], markersize=8, label='Pareto Front'),\\n\",\n",
    "    \"        Line2D([0], [0], marker='o', color='w', markerfacecolor=palette_colors['Best Balanced'], markersize=10, markeredgecolor='k', label='Best Balanced'),\\n\",\n",
    "    \"        Line2D([0], [0], color='black', lw=0, label=''), # Spacer\\n\",\n",
    "    \"        Line2D([0], [0], marker='o', color='w', markerfacecolor='gray', markeredgecolor='k', markersize=8, label='Mode: Amino Acids'),\\n\",\n",
    "    \"        Line2D([0], [0], marker='s', color='w', markerfacecolor='gray', markeredgecolor='k', markersize=8, label='Mode: Atoms'),\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"    ax.legend(handles=legend_elements, loc='upper left', frameon=True, fontsize=10)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Labels\\n\",\n",
    "    \"    ax.set_xlabel(\\\"P10\\\", fontsize=12, fontweight='bold')\\n\",\n",
    "    \"    ax.set_ylabel(\\\"P90\\\", fontsize=12, fontweight='bold')\\n\",\n",
    "    \"    ax.set_title(\\\"Optimization Landscape\\\", fontsize=14, pad=15)\\n\",\n",
    "    \"    ax.grid(True, linestyle='--', alpha=0.3)\\n\",\n",
    "    \"    sns.despine()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- ZOOM INSET ---\\n\",\n",
    "    \"    # We want to zoom into the region with the Pareto Front\\n\",\n",
    "    \"    # 1. Get bounds of Pareto points\\n\",\n",
    "    \"    pareto_df = df[df['Status'].isin(['Pareto Front', 'Best Balanced'])]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    x_min, x_max = pareto_df['P10'].min(), pareto_df['P10'].max()\\n\",\n",
    "    \"    y_min, y_max = pareto_df['P90'].min(), pareto_df['P90'].max()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Add padding (10%)\\n\",\n",
    "    \"    x_pad = (x_max - x_min) * 0.2\\n\",\n",
    "    \"    y_pad = (y_max - y_min) * 0.2\\n\",\n",
    "    \"    if x_pad == 0: x_pad = 0.01\\n\",\n",
    "    \"    if y_pad == 0: y_pad = 0.01\\n\",\n",
    "    \"\\n\",\n",
    "    \"    x_lims = (x_min - x_pad, x_max + x_pad)\\n\",\n",
    "    \"    y_lims = (y_min - y_pad, y_max + y_pad)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. Create Inset Axes (Location: Lower Right, size 35%)\\n\",\n",
    "    \"    axins = inset_axes(ax, width=\\\"35%\\\", height=\\\"35%\\\", loc='lower right', borderpad=2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 3. Plot points inside inset (Repeat logic)\\n\",\n",
    "    \"    # We only plot points that fall within limits to keep it clean,\\n\",\n",
    "    \"    # or just plot everything and let limits clip it.\\n\",\n",
    "    \"    for _, row in df.iterrows():\\n\",\n",
    "    \"        status = row['Status']\\n\",\n",
    "    \"        mode = row['Mode']\\n\",\n",
    "    \"\\n\",\n",
    "    \"        color = palette_colors[status]\\n\",\n",
    "    \"        marker = markers_map.get(mode, 'o')\\n\",\n",
    "    \"        edge = 'black' if status != 'Trial' else 'none'\\n\",\n",
    "    \"        alpha = 1.0 if status != 'Trial' else 0.4\\n\",\n",
    "    \"        z = 10 if status != 'Trial' else 1\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Calculate size\\n\",\n",
    "    \"        v_min, v_max = df['Median'].min(), df['Median'].max()\\n\",\n",
    "    \"        s = 50 + 200 * (row['Median'] - v_min) / (v_max - v_min + 1e-9)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        axins.scatter(\\n\",\n",
    "    \"            row['P10'], row['P90'],\\n\",\n",
    "    \"            s=s, c=color, marker=marker, edgecolors=edge, alpha=alpha, zorder=z\\n\",\n",
    "    \"        )\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Apply limits to inset\\n\",\n",
    "    \"    axins.set_xlim(*x_lims)\\n\",\n",
    "    \"    axins.set_ylim(*y_lims)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Remove ticks from inset for cleaner look (optional)\\n\",\n",
    "    \"    axins.set_xticklabels([])\\n\",\n",
    "    \"    axins.set_yticklabels([])\\n\",\n",
    "    \"    axins.grid(True, linestyle=':', alpha=0.5)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Connect inset to main plot\\n\",\n",
    "    \"    mark_inset(ax, axins, loc1=2, loc2=4, fc=\\\"none\\\", ec=\\\"0.5\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Save\\n\",\n",
    "    \"    plt.savefig(OUTPUT_FILE, dpi=300, bbox_inches='tight')\\n\",\n",
    "    \"    print(f\\\"Plot saved to {OUTPUT_FILE}\\\")\\n\",\n",
    "    \"    plt.show()\\n\",\n",
    "    \"\\n\",\n",
    "    \"if __name__ == \\\"__main__\\\":\\n\",\n",
    "    \"    main()\"\n",
    "   ],\n",
