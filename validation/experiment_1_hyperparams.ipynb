    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import mrcfile\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from scipy import stats\\n\",\n",
    "    \"def calculate_map_cc(map_path_1, map_path_2):\\n\",\n",
    "    \"    \\\"\\\"\\\"Calculates CC and returns a float. Returns 0.0 on error.\\\"\\\"\\\"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        # mmap=True uses disk instead of RAM for reading\\n\",\n",
    "    \"        with mrcfile.open(map_path_1, mode='r') as mrc1, \\\\\\n\",\n",
    "    \"             mrcfile.open(map_path_2, mode='r') as mrc2:\\n\",\n",
    "    \"\\n\",\n",
    "    \"            flat1 = mrc1.data.ravel()\\n\",\n",
    "    \"            flat2 = mrc2.data.ravel()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if flat1.shape != flat2.shape:\\n\",\n",
    "    \"                return 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Calculate Correlation\\n\",\n",
    "    \"            mean1 = np.mean(flat1, dtype=np.float64)\\n\",\n",
    "    \"            mean2 = np.mean(flat2, dtype=np.float64)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            c1 = flat1 - mean1\\n\",\n",
    "    \"            c2 = flat2 - mean2\\n\",\n",
    "    \"\\n\",\n",
    "    \"            numerator = np.dot(c1, c2)\\n\",\n",
    "    \"            denominator = np.linalg.norm(c1) * np.linalg.norm(c2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            res_spearman = stats.spearmanr(flat1, flat2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if denominator == 0:\\n\",\n",
    "    \"                return 0.0\\n\",\n",
    "    \"            return numerator / denominator, \\\"SPeearman:\\\", res_spearman.statistic, \\\"SPeearman P:\\\", res_spearman.pvalue\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        # Print error to stderr so it doesn't mess up the result parsing\\n\",\n",
    "    \"        print(f\\\"Error in CC calc: {e}\\\", file=sys.stderr)\\n\",\n",
    "    \"        return 0.0\"\n",
    "   ],\n",
