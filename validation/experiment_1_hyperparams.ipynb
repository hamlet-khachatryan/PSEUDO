    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-02-06T14:25:28.906141Z\",\n",
    "     \"start_time\": \"2026-02-06T14:25:28.885837Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import gemmi\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from scipy import stats, ndimage  # Added ndimage\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"\\n\",\n",
    "    \"def _compute_metrics(data1, data2):\\n\",\n",
    "    \"    \\\"\\\"\\\"Helper to calculate Pearson CC and Spearman for a given set of data.\\\"\\\"\\\"\\n\",\n",
    "    \"    if data1.size == 0 or data2.size == 0:\\n\",\n",
    "    \"        return 0.0, 0.0, 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Pearson Correlation\\n\",\n",
    "    \"    mean1 = np.mean(data1, dtype=np.float64)\\n\",\n",
    "    \"    mean2 = np.mean(data2, dtype=np.float64)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    c1 = data1 - mean1\\n\",\n",
    "    \"    c2 = data2 - mean2\\n\",\n",
    "    \"\\n\",\n",
    "    \"    numerator = np.dot(c1, c2)\\n\",\n",
    "    \"    denominator = np.linalg.norm(c1) * np.linalg.norm(c2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    pearson_cc = 0.0\\n\",\n",
    "    \"    if denominator != 0:\\n\",\n",
    "    \"        pearson_cc = numerator / denominator\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # Spearman Correlation\\n\",\n",
    "    \"    res_spearman = stats.spearmanr(data1, data2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    return pearson_cc, res_spearman.statistic, res_spearman.pvalue\\n\",\n",
    "    \"\\n\",\n",
    "    \"def calculate_split_map_cc(map_path_1, map_path_2, model_path):\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        # --- 1. READ MAPS WITH GEMMI ---\\n\",\n",
    "    \"        # setup(0.0) replaces NaNs with 0.0 to prevent errors\\n\",\n",
    "    \"        m1 = gemmi.read_ccp4_map(map_path_1)\\n\",\n",
    "    \"        m1.setup(0.0)\\n\",\n",
    "    \"        grid1 = m1.grid\\n\",\n",
    "    \"\\n\",\n",
    "    \"        m2 = gemmi.read_ccp4_map(map_path_2)\\n\",\n",
    "    \"        m2.setup(0.0)\\n\",\n",
    "    \"        grid2 = m2.grid\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- 2. MATCH GRID SHAPES (ROBUST RESAMPLING) ---\\n\",\n",
    "    \"        arr1 = np.array(grid1, copy=False)\\n\",\n",
    "    \"        arr2_raw = np.array(grid2, copy=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Check if dimensions match (nu, nv, nw)\\n\",\n",
    "    \"        if arr1.shape != arr2_raw.shape:\\n\",\n",
    "    \"            print(f\\\"Notice: Grid shape mismatch {arr1.shape} vs {arr2_raw.shape}. Resampling Map 2...\\\", file=sys.stderr)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # We calculate the scale factors to map indices from Grid 1 to Grid 2\\n\",\n",
    "    \"            # Shape is (nu, nv, nw)\\n\",\n",
    "    \"            factors = [\\n\",\n",
    "    \"                arr2_raw.shape[0] / arr1.shape[0], # u scale\\n\",\n",
    "    \"                arr2_raw.shape[1] / arr1.shape[1], # v scale\\n\",\n",
    "    \"                arr2_raw.shape[2] / arr1.shape[2]  # w scale\\n\",\n",
    "    \"            ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Create a coordinate grid for the target shape (Map 1)\\n\",\n",
    "    \"            # This generates the indices (0,0,0), (0,0,1)... for the new grid\\n\",\n",
    "    \"            coords = np.mgrid[0:arr1.shape[0], 0:arr1.shape[1], 0:arr1.shape[2]]\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Scale these coordinates to match the source grid (Map 2)\\n\",\n",
    "    \"            coords[0] = coords[0] * factors[0]\\n\",\n",
    "    \"            coords[1] = coords[1] * factors[1]\\n\",\n",
    "    \"            coords[2] = coords[2] * factors[2]\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Interpolate Map 2 at these coordinates\\n\",\n",
    "    \"            # mode='wrap' handles the periodic boundaries of the map (crystal lattice)\\n\",\n",
    "    \"            # order=1 is linear interpolation (standard), use 3 for cubic\\n\",\n",
    "    \"            arr2 = ndimage.map_coordinates(arr2_raw, coords, order=1, mode='wrap')\\n\",\n",
    "    \"\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            arr2 = arr2_raw\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- 3. GENERATE SOLVENT MASK ---\\n\",\n",
    "    \"        structure = gemmi.read_structure(model_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Create a grid for the mask that matches Map 1 exactly\\n\",\n",
    "    \"        mask_grid = grid1.clone()\\n\",\n",
    "    \"        mask_grid.fill(0)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        masker = gemmi.SolventMasker(gemmi.AtomicRadiiSet.Cctbx)\\n\",\n",
    "    \"        # 0 = Protein/Structure, 1 = Solvent\\n\",\n",
    "    \"        masker.put_mask_on_float_grid(mask_grid, structure[0])\\n\",\n",
    "    \"\\n\",\n",
    "    \"        mask_array = np.array(mask_grid, copy=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if arr1.size != mask_array.size:\\n\",\n",
    "    \"             print(f\\\"Error: Critical size mismatch. Map: {arr1.size}, Mask: {mask_array.size}\\\", file=sys.stderr)\\n\",\n",
    "    \"             return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- 4. PREPARE DATA ---\\n\",\n",
    "    \"        flat1 = arr1.ravel()\\n\",\n",
    "    \"        flat2 = arr2.ravel()\\n\",\n",
    "    \"        flat_mask = mask_array.ravel()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        results = {}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- 5. CALCULATE OVERALL CC ---\\n\",\n",
    "    \"        o_cc, o_sp, o_pval = _compute_metrics(flat1, flat2)\\n\",\n",
    "    \"        results['overall'] = {'cc': o_cc, 'spearman': o_sp, 'n': flat1.size}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- 6. SPLIT CALCULATION ---\\n\",\n",
    "    \"        # Gemmi SolventMasker: 1.0 is solvent, 0.0 is protein\\n\",\n",
    "    \"        is_solvent = flat_mask > 0.5\\n\",\n",
    "    \"        is_protein = ~is_solvent\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Protein Region\\n\",\n",
    "    \"        p_data1 = flat1[is_protein]\\n\",\n",
    "    \"        p_data2 = flat2[is_protein]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if p_data1.size > 0:\\n\",\n",
    "    \"            p_cc, p_sp, p_pval = _compute_metrics(p_data1, p_data2)\\n\",\n",
    "    \"            results['protein'] = {'cc': p_cc, 'spearman': p_sp, 'n': p_data1.size}\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            results['protein'] = {'cc': 0, 'spearman': 0, 'n': 0}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Solvent Region\\n\",\n",
    "    \"        s_data1 = flat1[is_solvent]\\n\",\n",
    "    \"        s_data2 = flat2[is_solvent]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if s_data1.size > 0:\\n\",\n",
    "    \"            s_cc, s_sp, s_pval = _compute_metrics(s_data1, s_data2)\\n\",\n",
    "    \"            results['solvent'] = {'cc': s_cc, 'spearman': s_sp, 'n': s_data1.size}\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            results['solvent'] = {'cc': 0, 'spearman': 0, 'n': 0}\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return results\\n\",\n",
    "    \"\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"Error in Split CC calc: {e}\\\", file=sys.stderr)\\n\",\n",
    "    \"        import traceback\\n\",\n",
    "    \"        traceback.print_exc()\\n\",\n",
    "    \"        return None\"\n",
    "   ],\n",
    "   \"id\": \"752ea6599bb2deb7\",\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 70\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
