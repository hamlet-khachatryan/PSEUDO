    "   \"source\": \"api.run_quantification(\\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_data/1ZY9\\\", k_factor=1.25, map_cap=50, stem=None, force=True)\",\n",
