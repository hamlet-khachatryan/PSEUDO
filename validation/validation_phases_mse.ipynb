    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import gemmi\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import subprocess\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- CONFIGURATION ---\\n\",\n",
    "    \"CHECKPOINT_FILE = \\\"phase_metrics_checkpoint.csv\\\"\\n\",\n",
    "    \"OUTPUT_PLOT_DIR = \\\"plots_output\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- 1. CORE CALCULATION ---\\n\",\n",
    "    \"def calculate_phase_metrics(ref_cif_path, map_path, label, structure_id, resolution):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Calculates Weighted MSE, RMSE, and Log-Likelihood (Cosine Score).\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    # Create temp dir for intermediate files to keep things clean\\n\",\n",
    "    \"    temp_dir = os.path.join(\\\"temp_phase_calc\\\", str(structure_id), label.replace(\\\" \\\", \\\"_\\\"))\\n\",\n",
    "    \"    os.makedirs(temp_dir, exist_ok=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    base_name = os.path.basename(map_path).replace('.ccp4', '').replace('.mrc', '')\\n\",\n",
    "    \"    mtz_out = os.path.join(temp_dir, f\\\"{base_name}_sf.mtz\\\")\\n\",\n",
    "    \"    cif_out = os.path.join(temp_dir, f\\\"{base_name}_fft.cif\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        # Validate inputs\\n\",\n",
    "    \"        if not os.path.exists(ref_cif_path): return None\\n\",\n",
    "    \"        if not os.path.exists(map_path): return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 1. Map -> MTZ\\n\",\n",
    "    \"        subprocess.run([\\\"gemmi\\\", \\\"map2sf\\\", map_path, mtz_out, \\\"FW-F\\\", \\\"PHIC\\\"],\\n\",\n",
    "    \"                       check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 2. MTZ -> CIF\\n\",\n",
    "    \"        subprocess.run([\\\"gemmi\\\", \\\"mtz2cif\\\", mtz_out, cif_out],\\n\",\n",
    "    \"                       check=True, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- Helper: Parse CIF for Phase & FOM ---\\n\",\n",
    "    \"        def get_data(filepath, extract_fom=False):\\n\",\n",
    "    \"            doc = gemmi.cif.read_file(filepath)\\n\",\n",
    "    \"            block = doc.sole_block()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Find Phase Tag\\n\",\n",
    "    \"            p_tags = ['_refln.phase_calc', '_refln.phase_meas', '_refln.F_phi', '_refln.phase_prob']\\n\",\n",
    "    \"            p_tag = next((t for t in p_tags if block.find_loop(t)), None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Find FOM Tag (only for reference)\\n\",\n",
    "    \"            fom_tag = None\\n\",\n",
    "    \"            if extract_fom:\\n\",\n",
    "    \"                f_tags = ['_refln.fom', '_refln.weight', '_refln.pdbx_fom']\\n\",\n",
    "    \"                fom_tag = next((t for t in f_tags if block.find_loop(t)), None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Extract\\n\",\n",
    "    \"            cols = ['_refln.index_h', '_refln.index_k', '_refln.index_l', p_tag]\\n\",\n",
    "    \"            if fom_tag: cols.append(fom_tag)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            try:\\n\",\n",
    "    \"                data = block.find(cols)\\n\",\n",
    "    \"            except:\\n\",\n",
    "    \"                return {}\\n\",\n",
    "    \"\\n\",\n",
    "    \"            result = {}\\n\",\n",
    "    \"            for row in data:\\n\",\n",
    "    \"                try:\\n\",\n",
    "    \"                    h, k, l = int(row[0]), int(row[1]), int(row[2])\\n\",\n",
    "    \"                    phi = (float(row[3]) + 180) % 360 - 180 # Canonicalize\\n\",\n",
    "    \"\\n\",\n",
    "    \"                    if extract_fom:\\n\",\n",
    "    \"                        w = float(row[4]) if len(row) > 4 else 1.0\\n\",\n",
    "    \"                        result[(h, k, l)] = (phi, w)\\n\",\n",
    "    \"                    else:\\n\",\n",
    "    \"                        result[(h, k, l)] = phi\\n\",\n",
    "    \"                except ValueError:\\n\",\n",
    "    \"                    continue\\n\",\n",
    "    \"            return result\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 3. Load Data\\n\",\n",
    "    \"        ref_data = get_data(ref_cif_path, extract_fom=True)\\n\",\n",
    "    \"        calc_data = get_data(cif_out, extract_fom=False)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 4. Intersect\\n\",\n",
    "    \"        common_hkls = set(ref_data.keys()) & set(calc_data.keys())\\n\",\n",
    "    \"        if not common_hkls: return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # 5. Calculate Weighted Metrics\\n\",\n",
    "    \"        w_sq_err_sum = 0.0\\n\",\n",
    "    \"        sum_weights = 0.0\\n\",\n",
    "    \"        ll_accum = 0.0\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for hkl in common_hkls:\\n\",\n",
    "    \"            phi_ref, fom = ref_data[hkl]\\n\",\n",
    "    \"            phi_calc = calc_data[hkl]\\n\",\n",
    "    \"\\n\",\n",
    "    \"            if fom <= 0.001: continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Circular Difference\\n\",\n",
    "    \"            diff = (phi_calc - phi_ref + 180) % 360 - 180\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Weighted Squared Error\\n\",\n",
    "    \"            w_sq_err_sum += fom * (diff**2)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Log Likelihood Proxy (Weighted Cosine)\\n\",\n",
    "    \"            ll_accum += fom * np.cos(np.deg2rad(diff))\\n\",\n",
    "    \"\\n\",\n",
    "    \"            sum_weights += fom\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if sum_weights == 0: return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Final Computations\\n\",\n",
    "    \"        w_mse = w_sq_err_sum / sum_weights\\n\",\n",
    "    \"        w_rmse = np.sqrt(w_mse)\\n\",\n",
    "    \"        mean_ll = ll_accum / sum_weights\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"  [{label}] N={len(common_hkls)} wMSE={w_mse:.1f} LL={mean_ll:.3f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return {\\n\",\n",
    "    \"            'id': structure_id,\\n\",\n",
    "    \"            'resolution': float(resolution),\\n\",\n",
    "    \"            'method': label,\\n\",\n",
    "    \"            'w_mse': w_mse,       # Weighted Mean Squared Error\\n\",\n",
    "    \"            'w_rmse': w_rmse,     # Weighted RMSE\\n\",\n",
    "    \"            'll_score': mean_ll,  # Likelihood Score\\n\",\n",
    "    \"            'n_reflections': len(common_hkls)\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"  [ERROR] {label}: {e}\\\")\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- 2. BATCH PROCESSING WITH CHECKPOINTS ---\\n\",\n",
    "    \"def process_csv_with_checkpoint(csv_path):\\n\",\n",
    "    \"    # 1. Load Checkpoint if exists\\n\",\n",
    "    \"    processed_keys = set()\\n\",\n",
    "    \"    if os.path.exists(CHECKPOINT_FILE):\\n\",\n",
    "    \"        print(f\\\"Found checkpoint file: {CHECKPOINT_FILE}. Resuming...\\\")\\n\",\n",
    "    \"        df_exist = pd.read_csv(CHECKPOINT_FILE)\\n\",\n",
    "    \"        # Create a set of \\\"id_method\\\" to verify what is done\\n\",\n",
    "    \"        for _, row in df_exist.iterrows():\\n\",\n",
    "    \"            processed_keys.add((str(row['id']), row['method']))\\n\",\n",
    "    \"    else:\\n\",\n",
    "    \"        # Create new file with headers\\n\",\n",
    "    \"        with open(CHECKPOINT_FILE, 'w') as f:\\n\",\n",
    "    \"            f.write(\\\"id,resolution,method,w_mse,w_rmse,ll_score,n_reflections\\\\n\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 2. Load Input CSV\\n\",\n",
    "    \"    df_meta = pd.read_csv(csv_path)\\n\",\n",
    "    \"    df_meta.columns = [c.lower().strip() for c in df_meta.columns]\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Total structures to process: {len(df_meta)}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # 3. Iterate\\n\",\n",
    "    \"    for idx, row in df_meta.iterrows():\\n\",\n",
    "    \"        sid = str(row['id'])\\n\",\n",
    "    \"        res = row['resolution']\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Define the 3 comparisons\\n\",\n",
    "    \"        tasks = [\\n\",\n",
    "    \"            (\\\"Debiased\\\", f\\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/exp_1/debias_validation_atoms_01/{sid}/quantify_results/k_0.2_cap_99/{sid}_p_value.ccp4\\\"),\\n\",\n",
    "    \"            (\\\"Baseline\\\", f\\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/merged_intensities/{sid}-sf/baseline_maps/{sid.lower()}_validation_2fo-fc_map_coef.ccp4\\\"),\\n\",\n",
    "    \"            (\\\"Calculated\\\", f\\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/merged_intensities/{sid}-sf/baseline_maps/calculated_density.ccp4\\\")\\n\",\n",
    "    \"        ]\\n\",\n",
    "    \"\\n\",\n",
    "    \"        ref_cif = f\\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/merged_intensities/{sid}-sf/{sid}_md.cif\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(f\\\"\\\\nProcessing {sid} ({res} A)...\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for label, map_path in tasks:\\n\",\n",
    "    \"            # CHECKPOINT CHECK: Skip if done\\n\",\n",
    "    \"            if (sid, label) in processed_keys:\\n\",\n",
    "    \"                # print(f\\\"  [SKIP] {label} already done.\\\")\\n\",\n",
    "    \"                continue\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Run Calculation\\n\",\n",
    "    \"            result = calculate_phase_metrics(ref_cif, map_path, label, sid, res)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Save to Checkpoint IMMEDIATELY\\n\",\n",
    "    \"            if result:\\n\",\n",
    "    \"                df_res = pd.DataFrame([result])\\n\",\n",
    "    \"                df_res.to_csv(CHECKPOINT_FILE, mode='a', header=False, index=False)\\n\",\n",
    "    \"                processed_keys.add((sid, label))\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(\\\"\\\\nProcessing Complete.\\\")\\n\",\n",
    "    \"    return pd.read_csv(CHECKPOINT_FILE)\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- 3. PLOTTING (SEPARATE FILES) ---\\n\",\n",
    "    \"def plot_all_metrics_separately(df):\\n\",\n",
    "    \"    if df.empty: return\\n\",\n",
    "    \"\\n\",\n",
    "    \"    os.makedirs(OUTPUT_PLOT_DIR, exist_ok=True)\\n\",\n",
    "    \"    plt.style.use('ggplot')\\n\",\n",
    "    \"    sns.set_palette(\\\"colorblind\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- PLOT 1: Weighted MSE vs Resolution ---\\n\",\n",
    "    \"    plt.figure(figsize=(10, 7))\\n\",\n",
    "    \"    sns.scatterplot(data=df, x='resolution', y='w_mse', hue='method', style='method', s=80, alpha=0.7)\\n\",\n",
    "    \"    # Add Trendlines\\n\",\n",
    "    \"    for method in df['method'].unique():\\n\",\n",
    "    \"        data_sub = df[df['method'] == method]\\n\",\n",
    "    \"        if len(data_sub) > 1:\\n\",\n",
    "    \"            sns.regplot(data=data_sub, x='resolution', y='w_mse', scatter=False, ci=None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.title(\\\"Weighted Mean Squared Error (MSE) vs Resolution\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Weighted MSE (Degrees^2)\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Resolution (Å)\\\")\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(f\\\"{OUTPUT_PLOT_DIR}/1_MSE_vs_Resolution.png\\\", dpi=300)\\n\",\n",
    "    \"    plt.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- PLOT 2: Log Likelihood vs Resolution ---\\n\",\n",
    "    \"    plt.figure(figsize=(10, 7))\\n\",\n",
    "    \"    sns.scatterplot(data=df, x='resolution', y='ll_score', hue='method', style='method', s=80, alpha=0.7)\\n\",\n",
    "    \"    for method in df['method'].unique():\\n\",\n",
    "    \"        data_sub = df[df['method'] == method]\\n\",\n",
    "    \"        if len(data_sub) > 1:\\n\",\n",
    "    \"            sns.regplot(data=data_sub, x='resolution', y='ll_score', scatter=False, ci=None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    plt.title(\\\"Log-Likelihood Score vs Resolution\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Weighted Mean Cosine (Higher is Better)\\\")\\n\",\n",
    "    \"    plt.xlabel(\\\"Resolution (Å)\\\")\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(f\\\"{OUTPUT_PLOT_DIR}/2_Likelihood_vs_Resolution.png\\\", dpi=300)\\n\",\n",
    "    \"    plt.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- PLOT 3: Distribution Boxplots (MSE) ---\\n\",\n",
    "    \"    plt.figure(figsize=(8, 6))\\n\",\n",
    "    \"    sns.boxplot(data=df, x='method', y='w_mse', width=0.5)\\n\",\n",
    "    \"    plt.title(\\\"Global Distribution: Weighted MSE\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"MSE (deg^2)\\\")\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(f\\\"{OUTPUT_PLOT_DIR}/3_Boxplot_MSE.png\\\", dpi=300)\\n\",\n",
    "    \"    plt.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- PLOT 4: Distribution Boxplots (Likelihood) ---\\n\",\n",
    "    \"    plt.figure(figsize=(8, 6))\\n\",\n",
    "    \"    sns.boxplot(data=df, x='method', y='ll_score', width=0.5)\\n\",\n",
    "    \"    plt.title(\\\"Global Distribution: Likelihood Score\\\")\\n\",\n",
    "    \"    plt.ylabel(\\\"Score\\\")\\n\",\n",
    "    \"    plt.tight_layout()\\n\",\n",
    "    \"    plt.savefig(f\\\"{OUTPUT_PLOT_DIR}/4_Boxplot_Likelihood.png\\\", dpi=300)\\n\",\n",
    "    \"    plt.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- PLOT 5: Delta Likelihood (Bar Chart) ---\\n\",\n",
    "    \"    # Pivot to compare Debiased vs Baseline\\n\",\n",
    "    \"    df_pivot = df.pivot(index='id', columns='method', values='ll_score')\\n\",\n",
    "    \"    if 'Debiased' in df_pivot.columns and 'Baseline' in df_pivot.columns:\\n\",\n",
    "    \"        plt.figure(figsize=(12, 8))\\n\",\n",
    "    \"        df_pivot['delta'] = df_pivot['Debiased'] - df_pivot['Baseline']\\n\",\n",
    "    \"        df_sorted = df_pivot.sort_values('delta', ascending=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        colors = ['red' if x < 0 else 'green' for x in df_sorted['delta']]\\n\",\n",
    "    \"        plt.barh(range(len(df_sorted)), df_sorted['delta'], color=colors)\\n\",\n",
    "    \"        plt.title(\\\"Likelihood Improvement (Debiased - Baseline)\\\")\\n\",\n",
    "    \"        plt.xlabel(\\\"Delta Score (Positive = Improvement)\\\")\\n\",\n",
    "    \"        plt.yticks([]) # Hide IDs to keep it clean\\n\",\n",
    "    \"        plt.axvline(0, color='black', linestyle='--', linewidth=1)\\n\",\n",
    "    \"        plt.tight_layout()\\n\",\n",
    "    \"        plt.savefig(f\\\"{OUTPUT_PLOT_DIR}/5_Delta_Improvement.png\\\", dpi=300)\\n\",\n",
    "    \"        plt.close()\\n\",\n",
    "    \"\\n\",\n",
    "    \"    print(f\\\"Plots saved to directory: {OUTPUT_PLOT_DIR}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- EXECUTION ---\\n\",\n",
    "    \"# csv_path = \\\"your_input_ids.csv\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"csv_path = \\\"/Users/hamletkhachatryan/Desktop/DPhil_projects/pseudo/pseudo_paper/merged_intensities/diamond/pdbs.csv\\\"\\n\",\n",
    "    \"df_final = process_csv_with_checkpoint(csv_path)\\n\",\n",
    "    \"plot_all_metrics_separately(df_final)\"\n",
    "   ],\n",
