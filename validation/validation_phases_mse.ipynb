   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"raw\",\n",
    "   \"source\": [\n",
    "    \"import gemmi\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import subprocess\\n\",\n",
    "    \"import os\\n\",\n",
    "    \"import sys\\n\",\n",
    "    \"\\n\",\n",
    "    \"def calculate_phase_metrics(ref_cif_path, map_path, model_path=None, output_dir=\\\".\\\"):\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"    Runs the Gemmi CLI pipeline (Map -> SF -> CIF) and calculates phase metrics.\\n\",\n",
    "    \"    Integrates origin diagnostics and automatic result interpretation.\\n\",\n",
    "    \"\\n\",\n",
    "    \"    Args:\\n\",\n",
    "    \"        ref_cif_path (str): Path to the reference CIF (ground truth phases).\\n\",\n",
    "    \"        map_path (str): Path to the experimental CCP4 map.\\n\",\n",
    "    \"        model_path (str, optional): Path to PDB/MMCIF model to check origin alignment.\\n\",\n",
    "    \"    \\\"\\\"\\\"\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 1. PRE-FLIGHT: ORIGIN & GRID DIAGNOSTICS ---\\n\",\n",
    "    \"    print(\\\"--- 1. Alignment Diagnostics ---\\\")\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        map_obj = gemmi.read_ccp4_map(map_path)\\n\",\n",
    "    \"        map_grid = map_obj.grid\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if model_path:\\n\",\n",
    "    \"            st = gemmi.read_structure(model_path)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Check 1: Unit Cell Compatibility\\n\",\n",
    "    \"            # We allow small Floating Point differences (e.g., 0.01 A)\\n\",\n",
    "    \"            if not st.cell.approx(map_grid.unit_cell, epsilon=0.01):\\n\",\n",
    "    \"                print(f\\\"CRITICAL WARNING: Unit Cell mismatch!\\\")\\n\",\n",
    "    \"                print(f\\\"  Map:   {map_grid.unit_cell}\\\")\\n\",\n",
    "    \"                print(f\\\"  Model: {st.cell}\\\")\\n\",\n",
    "    \"                print(\\\"  -> This guarantees high Phase Error.\\\")\\n\",\n",
    "    \"            else:\\n\",\n",
    "    \"                print(\\\"  [OK] Unit Cells match.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Check 2: Origin / Center of Mass\\n\",\n",
    "    \"            # A large distance between map center and model center implies a shift\\n\",\n",
    "    \"            model_com = st.calculate_center_of_mass()\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Gemmi maps usually start at 0,0,0. We check if the model is roughly inside.\\n\",\n",
    "    \"            # Convert COM to fractional coordinates\\n\",\n",
    "    \"            com_frac = map_grid.unit_cell.fractionalize(model_com)\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Map extent in fractional coords (usually 0 to 1 for full cell)\\n\",\n",
    "    \"            print(f\\\"  Model COM (Fractional): {com_frac.x:.2f}, {com_frac.y:.2f}, {com_frac.z:.2f}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"            # Heuristic: If model is outside [0, 1] and map is defined in [0, 1], we have a shift.\\n\",\n",
    "    \"            if (com_frac.x < -0.1 or com_frac.x > 1.1):\\n\",\n",
    "    \"                print(\\\"  WARNING: Model seems outside the standard unit cell. Check Origin.\\\")\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            print(\\\"  (Skipping origin check: No model_path provided)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"  Diagnostic Error: {e}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 2. RUN GEMMI CLI PIPELINE ---\\n\",\n",
    "    \"    print(\\\"\\\\n--- 2. Executing Gemmi CLI ---\\\")\\n\",\n",
    "    \"    os.makedirs(output_dir, exist_ok=True)\\n\",\n",
    "    \"    base_name = os.path.basename(map_path).replace('.ccp4', '').replace('.mrc', '')\\n\",\n",
    "    \"    mtz_out = os.path.join(output_dir, f\\\"{base_name}_sf.mtz\\\")\\n\",\n",
    "    \"    cif_out = os.path.join(output_dir, f\\\"{base_name}_fft.cif\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        # Step A: map2sf (Calculates SFs and Phases)\\n\",\n",
    "    \"        cmd_map2sf = [\\\"gemmi\\\", \\\"map2sf\\\", map_path, mtz_out, \\\"FW-F\\\", \\\"PHIC\\\"]\\n\",\n",
    "    \"        subprocess.run(cmd_map2sf, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Step B: mtz2cif (Converts to readable CIF)\\n\",\n",
    "    \"        cmd_mtz2cif = [\\\"gemmi\\\", \\\"mtz2cif\\\", mtz_out, cif_out]\\n\",\n",
    "    \"        subprocess.run(cmd_mtz2cif, check=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)\\n\",\n",
    "    \"\\n\",\n",
    "    \"    except subprocess.CalledProcessError as e:\\n\",\n",
    "    \"        print(f\\\"CLI Error: {e.stderr}\\\", file=sys.stderr)\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"    # --- 3. PARSE PHASES ---\\n\",\n",
    "    \"    print(\\\"\\\\n--- 3. Parsing & Comparing ---\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"    def get_phases(filepath):\\n\",\n",
    "    \"        doc = gemmi.cif.read_file(filepath)\\n\",\n",
    "    \"        block = doc.sole_block()\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # Priority list for phase labels\\n\",\n",
    "    \"        labels = ['_refln.phase_calc', '_refln.phase_meas', '_refln.F_phi']\\n\",\n",
    "    \"        tag = next((t for t in labels if block.find_loop(t)), None)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # If not found in main loop, search deeper\\n\",\n",
    "    \"        if not tag:\\n\",\n",
    "    \"             for item in block:\\n\",\n",
    "    \"                if isinstance(item, gemmi.cif.Loop):\\n\",\n",
    "    \"                    for t in labels:\\n\",\n",
    "    \"                        if t in item.tags: tag = t\\n\",\n",
    "    \"\\n\",\n",
    "    \"        if not tag: raise ValueError(f\\\"No phase tag found in {filepath}\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        data = block.find(['_refln.index_h', '_refln.index_k', '_refln.index_l', tag])\\n\",\n",
    "    \"        return {(int(r[0]), int(r[1]), int(r[2])): (float(r[3]) + 180) % 360 - 180 for r in data}\\n\",\n",
    "    \"\\n\",\n",
    "    \"    try:\\n\",\n",
    "    \"        ref_data = get_phases(ref_cif_path)\\n\",\n",
    "    \"        calc_data = get_phases(cif_out)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        common_hkls = set(ref_data.keys()) & set(calc_data.keys())\\n\",\n",
    "    \"        if not common_hkls:\\n\",\n",
    "    \"            print(\\\"Error: No common reflections found.\\\")\\n\",\n",
    "    \"            return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- 4. CALCULATE METRICS ---\\n\",\n",
    "    \"        sq_errors = []\\n\",\n",
    "    \"        cos_diffs = [] # For Correlation Coefficient\\n\",\n",
    "    \"\\n\",\n",
    "    \"        for hkl in common_hkls:\\n\",\n",
    "    \"            d = (calc_data[hkl] - ref_data[hkl] + 180) % 360 - 180\\n\",\n",
    "    \"            sq_errors.append(d**2)\\n\",\n",
    "    \"            # Cosine of difference: 1.0 is perfect, 0.0 is orthogonal/random, -1.0 is inverse\\n\",\n",
    "    \"            cos_diffs.append(np.cos(np.deg2rad(d)))\\n\",\n",
    "    \"\\n\",\n",
    "    \"        mse = np.mean(sq_errors)\\n\",\n",
    "    \"        rmse = np.sqrt(mse)\\n\",\n",
    "    \"        # Phase Correlation: Average cosine of the phase error\\n\",\n",
    "    \"        phase_cc = np.mean(cos_diffs)\\n\",\n",
    "    \"\\n\",\n",
    "    \"        results = {\\n\",\n",
    "    \"            'rmse': rmse,\\n\",\n",
    "    \"            'phase_cc': phase_cc,\\n\",\n",
    "    \"            'n': len(common_hkls)\\n\",\n",
    "    \"        }\\n\",\n",
    "    \"\\n\",\n",
    "    \"        # --- 5. INTERPRETATION ---\\n\",\n",
    "    \"        print(\\\"\\\\n--- 4. Results & Interpretation ---\\\")\\n\",\n",
    "    \"        print(f\\\"Reflections Compared: {results['n']}\\\")\\n\",\n",
    "    \"        print(f\\\"RMSE (Degrees):       {results['rmse']:.2f}\\\")\\n\",\n",
    "    \"        print(f\\\"Phase Correlation:    {results['phase_cc']:.3f} (Max 1.0)\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        print(\\\"\\\\n[ANALYSIS]: \\\", end=\\\"\\\")\\n\",\n",
    "    \"        if results['rmse'] < 45:\\n\",\n",
    "    \"            print(\\\"SUCCESS. Strong correlation. Structures align well.\\\")\\n\",\n",
    "    \"        elif results['rmse'] < 70:\\n\",\n",
    "    \"            print(\\\"WEAK. Structures are related but likely need refinement or have flexibility.\\\")\\n\",\n",
    "    \"        elif results['rmse'] < 95:\\n\",\n",
    "    \"            print(\\\"POOR / MISALIGNED. (Your case)\\\")\\n\",\n",
    "    \"            print(\\\" -> Values are better than random (104 deg), but too high for a solved structure.\\\")\\n\",\n",
    "    \"            print(\\\" -> Most Likely Cause: ORIGIN MISMATCH or Fractional Shift.\\\")\\n\",\n",
    "    \"        else:\\n\",\n",
    "    \"            print(\\\"RANDOM. No correlation detected. Maps might be completely unrelated.\\\")\\n\",\n",
    "    \"\\n\",\n",
    "    \"        return results\\n\",\n",
    "    \"\\n\",\n",
    "    \"    except Exception as e:\\n\",\n",
    "    \"        print(f\\\"Calculation Error: {e}\\\")\\n\",\n",
    "    \"        return None\\n\",\n",
    "    \"\\n\",\n",
    "    \"# --- Usage ---\\n\",\n",
    "    \"# calculate_phase_metrics(\\\"ref.cif\\\", \\\"map.ccp4\\\", model_path=\\\"model.pdb\\\")\"\n",
